---
---
<footer class="border-t themed-border themed-bg-2 mt-20">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 group">
          <img src="/favicon.svg" alt="Name Numerology Logo" class="w-7 h-7 group-hover:scale-110 transition-transform duration-200" />
          <span class="text-base font-bold tracking-tight">
            <span class="themed-text">Name</span><span class="gradient-text">Numerology</span>
          </span>
        </a>
        <p class="mt-3 text-sm themed-text-3 max-w-xs">
          Free Chaldean numerology tools to discover the hidden meanings in your name and unlock your life's potential.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold themed-text uppercase tracking-wider mb-4">Calculators</h3>
        <ul class="space-y-2.5">
          <li><a href="/name-analysis" class="text-sm themed-text-2 hover:themed-text transition-colors">Full Name Analysis</a></li>
          <li><a href="/life-path-calculator" class="text-sm themed-text-2 hover:themed-text transition-colors">Life Path Calculator</a></li>
          <li><a href="/lucky-number-finder" class="text-sm themed-text-2 hover:themed-text transition-colors">Lucky Number Finder</a></li>
          <li><a href="/soul-urge-calculator" class="text-sm themed-text-2 hover:themed-text transition-colors">Soul Urge Calculator</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold themed-text uppercase tracking-wider mb-4">Resources</h3>
        <ul class="space-y-2.5">
          <li><a href="/articles/baby-name-meaning-finder" class="text-sm themed-text-2 hover:themed-text transition-colors">Baby Name Meanings</a></li>
          <li><a href="/articles/astrological-name-analysis" class="text-sm themed-text-2 hover:themed-text transition-colors">Astrological Analysis</a></li>
          <li><a href="/faq" class="text-sm themed-text-2 hover:themed-text transition-colors">FAQ</a></li>
        </ul>
        <h3 class="text-xs font-semibold themed-text uppercase tracking-wider mb-4 mt-6">Company</h3>
        <ul class="space-y-2.5">
          <li><a href="/about" class="text-sm themed-text-2 hover:themed-text transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-sm themed-text-2 hover:themed-text transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold themed-text uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2.5">
          <li><a href="/privacy-policy" class="text-sm themed-text-2 hover:themed-text transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-and-conditions" class="text-sm themed-text-2 hover:themed-text transition-colors">Terms & Conditions</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t themed-border pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs themed-text-3">
        &copy; {new Date().getFullYear()} Name Numerology Hub · <a href="https://namenumerologyhub.com" class="hover:themed-text transition-colors">namenumerologyhub.com</a>
      </p>
      <div class="flex flex-wrap justify-center gap-5 text-xs themed-text-3">
        <a href="/privacy-policy" class="hover:themed-text transition-colors">Privacy</a>
        <a href="/terms-and-conditions" class="hover:themed-text transition-colors">Terms</a>
        <a href="/faq" class="hover:themed-text transition-colors">FAQ</a>
        <a href="/about" class="hover:themed-text transition-colors">About</a>
        <a href="/contact" class="hover:themed-text transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
