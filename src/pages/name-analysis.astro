  2: { title: "The Diplomat", planet: "🌙 Moon", element: "Water", color: "#06b6d4", emoji: "🕊️", keywords: ["Empathetic","Cooperative","Intuitive","Patient","Diplomatic"], luckyColors: "Silver, White, Cream", luckyDays: "Monday, Friday", compatible: [2, 4, 6], description: "Governed by the Moon, you feel everything deeply. Your name carries the vibration of harmony, partnership, and emotional intelligence. You are the bridge-builder, the peacemaker, the one who sees all sides of every story." },
