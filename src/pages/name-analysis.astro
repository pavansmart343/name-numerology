      // --- Letter Breakdown ---
      const letterEl = document.getElementById('letterBreakdown') as HTMLElement;
      letterEl.innerHTML = letters.map(({ l, v }) =>
        `<div class="flex flex-col items-center p-2 rounded-lg bg-[var(--bg-secondary)] min-w-[2.5rem]">
          <span class="text-sm font-bold themed-text">${l}</span>
          <span class="text-xs themed-text-3">${v}</span>
        </div>`
      ).join('');
      (document.getElementById('breakdownFormula') as HTMLElement).textContent = `${parts.join(' + ')} = ${rawSum} → reduced to ${num1}`;

      // --- Compatibility ---
      const compatCard = document.getElementById('compatibilityCard') as HTMLElement;
      if (partnerInput) {
        const { total: num2 } = nameToNumber(partnerInput);
        const { score, desc } = getCompat(num1, num2);
        const data2 = numberData[num2] ?? numberData[9];

        (document.getElementById('name1Label') as HTMLElement).textContent = primaryInput.split(' ')[0];
        const n1Badge = document.getElementById('name1NumBadge') as HTMLElement;
        n1Badge.textContent = num1.toString();
        n1Badge.className = `w-16 h-16 rounded-full flex items-center justify-center text-2xl font-black text-white mx-auto shadow-xl num-badge-${Math.min(num1,9)}`;

        (document.getElementById('name2Label') as HTMLElement).textContent = partnerInput.split(' ')[0];
