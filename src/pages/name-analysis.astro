    function reduce(n: number): number {
      while (n > 9 && n !== 11 && n !== 22 && n !== 33)
        n = String(n).split('').reduce((s,d) => s + parseInt(d), 0);
      return n;
    }

    function nameToNumber(name: string) {
      const clean = name.toLowerCase().replace(/[^a-z]/g,'');
      let total = 0; let parts: string[] = []; let letters: {l:string,v:number}[] = [];
      for (const c of clean) {
        const v = chaldean[c] ?? 0;
        if (v) { total += v; parts.push(`${v}`); letters.push({l:c.toUpperCase(),v}); }
      }
      return { total: reduce(total), rawSum: total, parts, letters };
    }

    const compat: Record<string, number> = {
      '1-1':70,'1-2':60,'1-3':80,'1-4':75,'1-5':65,'1-6':55,'1-7':70,'1-8':85,'1-9':60,
      '2-3':65,'2-4':80,'2-5':50,'2-6':90,'2-7':75,'2-8':55,'2-9':70,
      '3-4':60,'3-5':85,'3-6':70,'3-7':65,'3-8':60,'3-9':80,
      '4-5':55,'4-6':85,'4-7':70,'4-8':75,'4-9':65,
      '5-6':60,'5-7':70,'5-8':65,'5-9':75,
      '6-7':65,'6-8':70,'6-9':90,'7-8':60,'7-9':70,'8-9':65,
    };

    function getCompat(n1: number, n2: number): { score: number; desc: string } {
      const key = [n1,n2].sort().join('-');
      const score = compat[key] ?? 65;
      let desc = '';
      if (score >= 85) desc = `🌟 Excellent compatibility! These name vibrations create a powerful, harmonious partnership. Your energies naturally amplify each other, creating a relationship greater than the sum of its parts.`;
      else if (score >= 70) desc = `✨ Good compatibility. These names complement each other well. With mutual respect, this pairing grows stronger and more harmonious over time.`;
      else if (score >= 55) desc = `⚡ Moderate compatibility. These vibrations create dynamic tension — challenging yet growth-promoting. Success requires conscious effort and open communication.`;
      else desc = `🔥 Challenging compatibility. These energies may conflict in certain areas. However, opposites can attract, and this pairing often produces powerful transformative growth.`;
      return { score, desc };
    }

    document.getElementById('nameHubForm')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const primaryInput = (document.getElementById('primaryName') as HTMLInputElement).value.trim();
      const partnerInput = (document.getElementById('partnerName') as HTMLInputElement).value.trim();
      if (!primaryInput) return;

      const { total: num1, rawSum, parts, letters } = nameToNumber(primaryInput);
      const data = numberData[num1] ?? numberData[9];

      // --- Main Number Card ---
      const bigDisplay = document.getElementById('bigNumberDisplay') as HTMLElement;
      bigDisplay.textContent = `${data.emoji} ${num1}`;
      bigDisplay.className = `shrink-0 w-24 h-24 md:w-32 md:h-32 rounded-2xl flex items-center justify-center text-3xl md:text-4xl font-black text-white shadow-2xl animate-pulse-glow num-badge-${Math.min(num1, 9)}`;

      const banner = document.getElementById('numberCardBanner') as HTMLElement;
      banner.style.background = `linear-gradient(90deg, ${data.color}, transparent)`;

      (document.getElementById('numberTitle') as HTMLElement).textContent = `${num1} · ${data.title}`;
      (document.getElementById('nameLabel') as HTMLElement).textContent = `Analysis for: ${primaryInput}`;
      (document.getElementById('numberDesc') as HTMLElement).textContent = data.description;

      const planetBadge = document.getElementById('planetBadge') as HTMLElement;
      planetBadge.textContent = data.planet;
      const elementBadge = document.getElementById('elementBadge') as HTMLElement;
      elementBadge.textContent = `${data.element} Element`;

      const keywordPills = document.getElementById('keywordPills') as HTMLElement;
      keywordPills.innerHTML = data.keywords.map((k: string) =>
        `<span class="px-3 py-1 text-xs font-semibold rounded-full border themed-border themed-text-2">${k}</span>`
      ).join('');

      (document.getElementById('luckyColors') as HTMLElement).textContent = data.luckyColors;
      (document.getElementById('luckyDays') as HTMLElement).textContent = data.luckyDays;
      (document.getElementById('compatible') as HTMLElement).textContent = `Numbers ${data.compatible.join(', ')}`;
      (document.getElementById('chaldeanSum') as HTMLElement).textContent = `${parts.join(' + ')} = ${rawSum} → ${num1}`;

      // --- Personality Traits ---
      const traitEmojis = ['💡','🎯','🧭','⚡','🌱'];
      const traitsEl = document.getElementById('personalityTraits') as HTMLElement;
      traitsEl.innerHTML = data.keywords.map((k: string, i: number) =>
        `<li class="flex items-center gap-3 p-3 rounded-xl bg-[var(--bg-secondary)] themed-text text-sm font-medium">
          <span class="text-lg">${traitEmojis[i % traitEmojis.length]}</span>
          ${k}
