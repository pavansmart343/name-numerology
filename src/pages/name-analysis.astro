  8: { title: "The Executive", planet: "♄ Saturn", element: "Earth", color: "#64748b", emoji: "💎", keywords: ["Ambitious","Authoritative","Goal-oriented","Resilient","Strategic"], luckyColors: "Black, Dark Gray, Dark Blue", luckyDays: "Saturday, Thursday", compatible: [2, 4, 8], description: "Saturn's karmic energy infuses your name with immense power and ambition. The number 8 is the number of material mastery — you understand that success requires discipline, sacrifice, and an unwavering long-term vision. You are built to lead organizations and accumulate lasting wealth." },
  9: { title: "The Humanitarian", planet: "♂ Mars", element: "Fire", color: "#ef4444", emoji: "🌟", keywords: ["Compassionate","Wise","Idealistic","Selfless","Creative"], luckyColors: "Red, Gold, Crimson", luckyDays: "Tuesday, Thursday", compatible: [3, 6, 9], description: "Dynamic Mars gives your name the fiery energy of compassion and universal love. The number 9 completes the cycle — you have lived many lifetimes and arrived at wisdom. Your deepest fulfillment comes from giving, healing, and leaving the world better than you found it." },
  11: { title: "The Visionary", planet: "🌙 Moon + ☀️ Sun", element: "All", color: "#f59e0b", emoji: "✨", keywords: ["Inspirational","Intuitive","Idealistic","Sensitive","Illuminated"], luckyColors: "Silver, Gold, White", luckyDays: "Sunday, Monday", compatible: [2, 11, 22], description: "You carry a Master Number — a rare, powerful vibration that bridges the earthly and the divine. Your name resonates with extraordinary spiritual intuition and the ability to inspire masses. The challenge is managing your extreme sensitivity while fulfilling your role as an illuminator." },
  22: { title: "The Master Builder", planet: "♀ Venus + ♄ Saturn", element: "Earth", color: "#8b5cf6", emoji: "🏗️", keywords: ["Visionary","Disciplined","Masterful","Ambitious","Practical"], luckyColors: "Purple, Gold, Earth Tones", luckyDays: "Saturday, Friday", compatible: [4, 8, 22], description: "The 22 is the most powerful number in numerology. Your name carries the vibration of the Master Builder — the ability to manifest the greatest visions in human history into concrete, lasting reality. You are here to make an extraordinary contribution to civilization." },
