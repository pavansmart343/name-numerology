        (document.getElementById('compatPercent') as HTMLElement).textContent = `${score}% Match`;
        (document.getElementById('compatibilityDesc') as HTMLElement).textContent = desc;

        setTimeout(() => {
          (document.getElementById('compatBar') as HTMLElement).style.width = score + '%';
