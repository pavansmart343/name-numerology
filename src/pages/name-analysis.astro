  4: { title: "The Builder", planet: "♄ Saturn", element: "Earth", color: "#6366f1", emoji: "🏛️", keywords: ["Disciplined","Reliable","Methodical","Loyal","Practical"], luckyColors: "Navy Blue, Dark Green, Brown", luckyDays: "Saturday, Sunday", compatible: [2, 4, 8], description: "Saturn, the great taskmaster, governs your name. The number 4 is the foundation of all things — you build empires brick by brick. Your reliability is legendary, and your practical wisdom creates lasting structures in every area of life." },
  5: { title: "The Explorer", planet: "☿ Mercury", element: "Air", color: "#10b981", emoji: "🌍", keywords: ["Adventurous","Adaptable","Charismatic","Curious","Free-spirited"], luckyColors: "Turquoise, Silver, Green", luckyDays: "Wednesday, Friday", compatible: [1, 3, 5], description: "Quick-witted Mercury rules your name, filling it with the energy of travel, communication, and perpetual curiosity. You resist all forms of restriction — your soul was built for freedom, new experiences, and the thrill of discovery." },
  6: { title: "The Nurturer", planet: "♀ Venus", element: "Earth", color: "#ec4899", emoji: "💗", keywords: ["Compassionate","Protective","Artistic","Generous","Responsible"], luckyColors: "Rose, Turquoise, Lavender", luckyDays: "Friday, Wednesday", compatible: [2, 4, 6], description: "Venus, goddess of love and beauty, blesses your name. The number 6 carries the highest vibration of love — unconditional, nurturing, and all-encompassing. Your home is your sanctuary, and you pour healing energy into everyone you love." },
