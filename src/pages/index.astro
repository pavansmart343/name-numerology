---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    question: "What is name numerology?",
    answer: "Name numerology is the study of the mystical relationship between numbers and the letters in a person's name. Using systems like Chaldean or Pythagorean numerology, each letter is assigned a numerical value. The sum of these values, reduced to a single digit or Master Number, reveals personality traits, destiny, and life tendencies."
  },
  {
    question: "How do I calculate my name numerology number?",
    answer: "To calculate your name numerology number using the Chaldean system, assign each letter a value (A=1, B=2, C=3, D=4, E=5, F=8, G=3, H=5, I=1, J=1, K=2, L=3, M=4, N=5, O=7, P=8, Q=1, R=2, S=3, T=4, U=6, V=6, W=6, X=5, Y=1, Z=7). Add all values together, then reduce to a single digit by adding the digits of the sum. Use our free Name Hub tool to get an instant calculation."
  },
  {
    question: "What is the difference between Chaldean and Pythagorean numerology?",
    answer: "Chaldean numerology, originating in ancient Babylon, assigns values 1–8 to letters (9 is considered sacred). Pythagorean (Western) numerology assigns values 1–9 sequentially to the alphabet. Chaldean is considered older and more accurate by many numerologists, while Pythagorean is simpler and more widely used in Western practice. We use the Chaldean system for our calculations."
  },
  {
    question: "What is a Life Path number?",
    answer: "A Life Path number is calculated from your date of birth by reducing the month, day, and year to single digits and adding them together. It is one of the most important numbers in numerology, revealing your life's purpose, the opportunities you'll encounter, and the challenges you'll face on your journey."
  },
  {
    question: "What is a Soul Urge number?",
    answer: "The Soul Urge number (also called the Heart's Desire number) is calculated from the vowels in your full birth name. It reveals your innermost cravings, hidden motivations, and what you truly value deep in your soul — the desires that drive your decisions, even unconsciously."
  },
  {
    question: "What is name compatibility in numerology?",
    answer: "Name compatibility in numerology compares the Expression Numbers (name numerology numbers) of two people to assess the harmony between their energies. Some number combinations naturally support and uplift each other (like 1 and 8, or 2 and 6), while others may create friction. Our Name Hub tool calculates a compatibility score for any two names."
  },
  {
    question: "Which name number is the luckiest?",
    answer: "In numerology, no number is universally 'luckiest' — each has unique strengths. However, numbers 1, 3, 6, and 9 are often considered highly favorable. Master Numbers 11, 22, and 33 carry exceptional potential but also significant challenges. The best number for you depends on your Life Path number and birth chart."
  },
  {
    question: "Can I change my luck by changing my name?",
    answer: "Name correction is a popular practice where people slightly alter their name spelling to achieve a more favorable numerology number. Many people report positive changes after a name correction. However, it should be done thoughtfully — the new name must be consistently used in daily life for the vibration to take effect. Consult a numerologist before making changes."
  },
  {
    question: "What is an astrological name analysis?",
    answer: "Astrological name analysis combines Chaldean numerology with Vedic astrology to understand how your name number aligns with your planetary rulers and zodiac sign. Each numerology number (1–9) is governed by a specific planet (e.g., 1 = Sun, 2 = Moon, 8 = Saturn). Aligning your name with your dominant planetary energy is considered highly auspicious."
  },
  {
    question: "How do I find the best name for my baby using numerology?",
    answer: "To find the best baby name using numerology: 1) Calculate the name numbers for your shortlisted names using our Baby Name tool. 2) Check compatibility with both parents' Life Path numbers. 3) Consider names whose number aligns with the baby's birth date (if known). 4) Favor names with Master Numbers (11, 22) or highly harmonious numbers (1, 3, 6, 9) for a strong foundation."
  }
];
---

<Layout 
  title="Name Numerology Calculator" 
  description="Calculate your name numerology for English and Western names using the ancient Chaldean system. Find your name number, life path, lucky numbers, soul urge, and compatibility score instantly."
>
  <!-- JSON-LD FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.answer
      }
    }))
  })} />

  <!-- JSON-LD WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Name Numerology Hub",
    "url": "https://namenumerologyhub.com",
    "description": "Free Chaldean name numerology calculator for name number, life path, soul urge, lucky numbers, and compatibility scores.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://namenumerologyhub.com/name-analysis?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

  <div class="relative overflow-hidden">
    <!-- Background Glows -->
    <div class="absolute -top-40 -z-10 left-1/2 -translate-x-1/2 transform-gpu blur-3xl sm:-top-80" aria-hidden="true">
      <div class="aspect-[1155/678] w-[36.125rem] bg-gradient-to-tr from-purple-500 to-cyan-400 opacity-20 sm:w-[72.1875rem]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
    </div>

    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-24 md:py-32 flex flex-col items-center text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6">
        Unlock the Power of <br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400">Name Numerology</span>
      </h1>
      <p class="mt-4 text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto mb-10">
        Discover hidden meanings, compatibility scores, and personality traits. Our advanced Chaldean calculators provide instant, accurate predictions based on the vibrations of your name. This calculator is designed for Western names and uses the Chaldean system — the most widely used numerology method in the UK, US, and Australia.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/name-analysis" class="bg-white text-black px-8 py-3 rounded-full font-semibold hover:bg-zinc-200 transition-colors">
          Analyze My Name
        </a>
        <a href="#core-tools" class="bg-zinc-900/80 backdrop-blur text-white border border-zinc-800 px-8 py-3 rounded-full font-semibold hover:bg-zinc-800 transition-colors">
          Explore Tools
        </a>
      </div>
    </div>
  </div>

  <!-- Core Tools -->
  <div id="core-tools" class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-20">
    <div class="mb-12">
      <h2 class="text-3xl font-bold tracking-tight text-white">The Core Tools</h2>
      <p class="mt-2 text-zinc-400">Deep dive into specific aspects of your numerology profile.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/life-path-calculator" class="group block bg-zinc-900/50 border border-zinc-800 backdrop-blur-md rounded-2xl p-6 hover:border-purple-500/50 hover:bg-zinc-800/50 transition-all duration-300">
        <div class="h-12 w-12 rounded-lg bg-zinc-800 flex items-center justify-center mb-6 text-2xl group-hover:bg-purple-500/20 group-hover:text-purple-400 transition-colors">🌱</div>
        <h3 class="text-xl font-semibold text-white mb-2">Life Path Calculator</h3>
        <p class="text-zinc-400 text-sm">Calculate your life path number based on your birth date to reveal your life's journey.</p>
      </a>
      <a href="/lucky-number-finder" class="group block bg-zinc-900/50 border border-zinc-800 backdrop-blur-md rounded-2xl p-6 hover:border-cyan-500/50 hover:bg-zinc-800/50 transition-all duration-300">
        <div class="h-12 w-12 rounded-lg bg-zinc-800 flex items-center justify-center mb-6 text-2xl group-hover:bg-cyan-500/20 group-hover:text-cyan-400 transition-colors">🍀</div>
        <h3 class="text-xl font-semibold text-white mb-2">Lucky Number Finder</h3>
        <p class="text-zinc-400 text-sm">Discover numbers that resonate harmoniously with your personal vibrations.</p>
      </a>
      <a href="/soul-urge-calculator" class="group block bg-zinc-900/50 border border-zinc-800 backdrop-blur-md rounded-2xl p-6 hover:border-purple-500/50 hover:bg-zinc-800/50 transition-all duration-300">
        <div class="h-12 w-12 rounded-lg bg-zinc-800 flex items-center justify-center mb-6 text-2xl group-hover:bg-purple-500/20 group-hover:text-purple-400 transition-colors">❤️</div>
        <h3 class="text-xl font-semibold text-white mb-2">Soul Urge Calculator</h3>
        <p class="text-zinc-400 text-sm">Find your heart's desire number using the vowels in your name to understand true motivations.</p>
      </a>
    </div>
  </div>

  <!-- Name Hub Section -->
  <div class="border-t border-white/5 bg-zinc-950">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-24">
      <div class="md:flex md:items-center md:justify-between mb-12">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-white">The Name Hub</h2>
          <p class="mt-2 text-zinc-400">Your all-in-one unified name analysis dashboard.</p>
        </div>
        <div class="mt-6 md:mt-0">
          <a href="/name-analysis" class="inline-flex items-center text-sm font-medium text-cyan-400 hover:text-cyan-300">
            Go to Hub
            <svg class="ml-1 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
      <div class="bg-gradient-to-br from-zinc-900 to-black border border-zinc-800 rounded-3xl p-8 md:p-12 relative overflow-hidden">
        <div class="relative z-10">
          <h3 class="text-2xl font-bold text-white mb-4">Complete Name Analysis Report</h3>
          <ul class="space-y-4 mb-8 text-zinc-300">
            <li class="flex items-center gap-3"><div class="h-2 w-2 rounded-full bg-cyan-400"></div><strong>Name Numerology Number:</strong> Destiny and expression predictions.</li>
            <li class="flex items-center gap-3"><div class="h-2 w-2 rounded-full bg-purple-400"></div><strong>Name Compatibility Score:</strong> See how well two names match.</li>
            <li class="flex items-center gap-3"><div class="h-2 w-2 rounded-full bg-pink-400"></div><strong>Name Personality Traits:</strong> Understand how others perceive you.</li>
          </ul>
          <a href="/name-analysis" class="inline-block bg-white text-black px-6 py-3 rounded-lg font-semibold hover:bg-zinc-200 transition-colors">Start Full Analysis</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Articles Section -->
  <div id="articles" class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-20">
    <div class="mb-12 text-center md:text-left">
      <h2 class="text-3xl font-bold tracking-tight text-white">Articles & Insights</h2>
      <p class="mt-2 text-zinc-400">Explore in-depth meaning and astrological analysis.</p>
      <p class="mt-3 text-zinc-400 text-sm">Not sure which numerology system is right for you? Read our guide: <a href="/articles/chaldean-vs-pythagorean-numerology" class="text-purple-400 hover:text-purple-300 underline underline-offset-2 transition-colors">Chaldean vs Pythagorean — Which is Better for English Names?</a></p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <a href="/articles/baby-name-meaning-finder" class="group relative bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden hover:border-zinc-700 transition-colors">
        <div class="h-48 bg-zinc-800 bg-cover bg-center opacity-40 group-hover:opacity-60 transition-opacity" style="background-image:url('https://images.unsplash.com/photo-1519689680058-324335c77eba?auto=format&fit=crop&q=80&w=800')"></div>
        <div class="p-6">
          <h3 class="text-xl font-bold text-white mb-2">Baby Name Meaning Finder</h3>
          <p class="text-zinc-400 mb-4">Looking for the perfect baby name? Discover the hidden vibrations and meanings behind popular and unique names to give your child a strong start.</p>
          <span class="text-purple-400 font-medium text-sm group-hover:underline">Read Guide &rarr;</span>
        </div>
      </a>
      <a href="/articles/astrological-name-analysis" class="group relative bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden hover:border-zinc-700 transition-colors">
        <div class="h-48 bg-zinc-800 bg-cover bg-center opacity-40 group-hover:opacity-60 transition-opacity" style="background-image:url('https://images.unsplash.com/photo-1532968961962-8a0cb3a2d4f5?auto=format&fit=crop&q=80&w=800')"></div>
        <div class="p-6">
          <h3 class="text-xl font-bold text-white mb-2">Astrological Name Analysis</h3>
          <p class="text-zinc-400 mb-4">How do the planets align with your name? Learn about the intersection of Chaldean numerology and Vedic astrology for deeper personal insights.</p>
          <span class="text-cyan-400 font-medium text-sm group-hover:underline">Read Guide &rarr;</span>
        </div>
      </a>
      <a href="/articles/western-name-numerology-meanings" class="group relative bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden hover:border-zinc-700 transition-colors">
        <div class="h-48 bg-zinc-800 bg-cover bg-center opacity-40 group-hover:opacity-60 transition-opacity" style="background-image:url('https://images.unsplash.com/photo-1455390582262-044cdead277a?auto=format&fit=crop&q=80&w=800')"></div>
        <div class="p-6">
          <h3 class="text-xl font-bold text-white mb-2">Western Name Numerology Meanings</h3>
          <p class="text-zinc-400 mb-4">Discover the Chaldean numerology number for Emma, Oliver, Sophia, James and more — with instant calculations and personality insights.</p>
          <span class="text-purple-400 font-medium text-sm group-hover:underline">Read Guide &rarr;</span>
        </div>
      </a>
    </div>
  </div>

  <!-- FAQ Section -->
  <div class="border-t border-white/5 bg-zinc-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold tracking-tight text-white">Frequently Asked Questions</h2>
        <p class="mt-2 text-zinc-400">Everything you need to know about name numerology.</p>
      </div>
      <div class="space-y-4" id="faqAccordion">
        {faqs.map((faq, i) => (
          <div class="faq-item border border-zinc-800 rounded-xl overflow-hidden bg-zinc-900/50">
            <button
              class="faq-btn w-full flex items-center justify-between text-left px-6 py-5 text-white font-medium hover:bg-zinc-800/50 transition-colors"
              aria-expanded="false"
              data-index={i}
            >
              <span class="pr-4">{faq.question}</span>
              <svg class="faq-icon shrink-0 w-5 h-5 text-zinc-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-answer hidden px-6 pb-5 text-zinc-400 text-sm leading-relaxed">
              {faq.answer}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script>
    document.querySelectorAll('.faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const icon = btn.querySelector('.faq-icon') as HTMLElement;
        const isOpen = !answer.classList.contains('hidden');

        // Close all others
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon').forEach(ic => ic.style.transform = 'rotate(0deg)');
        document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));

        if (!isOpen) {
          answer.classList.remove('hidden');
          icon.style.transform = 'rotate(180deg)';
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>
</Layout>
