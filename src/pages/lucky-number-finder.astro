---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lucky Number Finder" description="Discover your lucky numbers based on your birth date using Chaldean numerology. Find your personal lucky days, colors, and compatible vibrations.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12 md:py-20">

    <div class="mb-10 text-center no-print">
      <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-widest mb-4 bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">Core Tool</span>
      <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight themed-text mb-4">Lucky Number <span class="gradient-text">Finder</span></h1>
      <p class="themed-text-2 text-lg max-w-xl mx-auto">Discover the numbers that resonate most harmoniously with your personal energy — and learn the best days, colors, and timing to maximize your luck.</p>
    </div>

    <div class="themed-card rounded-2xl p-6 md:p-10 mb-8 no-print">
      <form id="luckyNumberForm" class="space-y-6">
        <div>
          <label for="dob" class="block text-sm font-semibold themed-text mb-2">Date of Birth <span class="text-red-400">*</span></label>
          <input type="date" id="dob" required
            class="themed-input w-full rounded-xl px-4 py-3 text-base"
          />
        </div>
        <button type="submit"
          class="w-full bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 text-white font-bold px-6 py-3.5 rounded-xl transition-all duration-200 shadow-lg shadow-cyan-500/25 hover:-translate-y-0.5"
        >
          Find My Lucky Numbers 🍀
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="resultContainer" class="hidden space-y-5">

      <!-- Action bar -->
      <div class="flex items-center justify-between no-print">
        <p class="text-sm themed-text-2">Your lucky vibrations revealed 🌟</p>
        <button onclick="window.print()" class="flex items-center gap-2 px-4 py-2 rounded-lg themed-card text-sm font-medium themed-text hover:scale-105 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
          Print
        </button>
      </div>

      <!-- Lucky Numbers Display -->
      <div class="result-card themed-card rounded-2xl p-6 md:p-8 print-section">
        <h2 class="text-sm font-semibold themed-text-2 uppercase tracking-wider mb-5">Your Lucky Numbers</h2>
        <div id="numbersGrid" class="flex flex-wrap justify-center gap-4 mb-6"></div>
        <p id="numbersDesc" class="text-sm themed-text-2 leading-relaxed text-center"></p>
      </div>

      <!-- Key Numbers Info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <!-- Root Number card -->
        <div class="result-card themed-card rounded-2xl p-6 print-section">
          <div class="flex items-start gap-4 mb-4">
            <div id="rootBadge" class="w-14 h-14 rounded-xl flex items-center justify-center text-2xl font-black text-white shrink-0"></div>
            <div>
              <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">Root Number</span>
              <h3 id="rootTitle" class="text-lg font-bold themed-text mt-1"></h3>
              <p id="rootDesc" class="text-xs themed-text-2 mt-0.5"></p>
            </div>
          </div>
          <div class="pt-4 border-t themed-border grid grid-cols-2 gap-3 text-center">
            <div>
              <p class="text-xs themed-text-3 mb-1">Lucky Colors</p>
              <p id="rootColors" class="text-xs font-medium themed-text"></p>
            </div>
            <div>
              <p class="text-xs themed-text-3 mb-1">Ruling Planet</p>
              <p id="rootPlanet" class="text-xs font-medium themed-text"></p>
            </div>
          </div>
        </div>

        <!-- Life Path card -->
        <div class="result-card themed-card rounded-2xl p-6 print-section">
          <div class="flex items-start gap-4 mb-4">
            <div id="lpBadge" class="w-14 h-14 rounded-xl flex items-center justify-center text-2xl font-black text-white shrink-0"></div>
            <div>
              <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20">Life Path</span>
              <h3 id="lpTitle" class="text-lg font-bold themed-text mt-1"></h3>
              <p id="lpDesc" class="text-xs themed-text-2 mt-0.5"></p>
            </div>
          </div>
          <div class="pt-4 border-t themed-border grid grid-cols-2 gap-3 text-center">
            <div>
              <p class="text-xs themed-text-3 mb-1">Lucky Days</p>
              <p id="lpDays" class="text-xs font-medium themed-text"></p>
            </div>
            <div>
              <p class="text-xs themed-text-3 mb-1">Compatible With</p>
              <p id="lpCompat" class="text-xs font-medium themed-text"></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Lucky Timing Tips -->
      <div class="result-card themed-card rounded-2xl p-6 print-section">
        <h3 class="font-bold themed-text mb-4 flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center">⏰</span>
          How to Use Your Lucky Numbers
        </h3>
        <div id="timingTips" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      </div>

      <!-- Next step -->
      <div class="result-card themed-card rounded-2xl p-6 no-print">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div>
            <h3 class="font-bold themed-text mb-1">Want your name's vibration too?</h3>
            <p class="text-sm themed-text-2">Combine lucky numbers with your name numerology for a complete portrait.</p>
          </div>
          <a href="/name-analysis" class="shrink-0 px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-600 to-cyan-600 text-white font-semibold text-sm hover:scale-105 transition-all shadow-lg shadow-purple-500/20">
            Name Analysis →
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    function reduce(n: number): number {
      while (n > 9) n = String(n).split('').reduce((s,d) => s + parseInt(d), 0);
      return n;
    }

    const numInfo: Record<number, { emoji:string; planet:string; colors:string; days:string; compat:string; title:string; desc:string }> = {
      1: { emoji:"👑", planet:"☀️ Sun", colors:"Gold, Yellow, Orange", days:"Sunday, Monday", compat:"1, 3, 5", title:"The Leader", desc:"A number of initiative, new beginnings, and independence." },
      2: { emoji:"🌙", planet:"🌙 Moon", colors:"Silver, White, Cream", days:"Monday, Friday", compat:"2, 6, 4", title:"The Partner", desc:"A number of cooperation, balance, and emotional depth." },
      3: { emoji:"🎨", planet:"♃ Jupiter", colors:"Yellow, Purple, Orange", days:"Thursday, Wednesday", compat:"3, 1, 9", title:"The Creator", desc:"A number of creativity, communication, and joyful expression." },
      4: { emoji:"🏛️", planet:"♄ Saturn", colors:"Navy, Green, Brown", days:"Saturday, Sunday", compat:"4, 2, 8", title:"The Builder", desc:"A number of structure, discipline, and long-term planning." },
      5: { emoji:"🌍", planet:"☿ Mercury", colors:"Turquoise, Silver, Green", days:"Wednesday, Friday", compat:"5, 1, 3", title:"The Explorer", desc:"A number of change, freedom, and adventurous opportunities." },
      6: { emoji:"💗", planet:"♀ Venus", colors:"Pink, Lavender, Turquoise", days:"Friday, Wednesday", compat:"6, 2, 9", title:"The Nurturer", desc:"A number of love, home, harmony, and creative beauty." },
      7: { emoji:"🔮", planet:"♆ Neptune", colors:"Deep Purple, Indigo, Gray", days:"Saturday, Sunday", compat:"7, 2, 9", title:"The Seeker", desc:"A number of wisdom, spiritual insight, and inner knowing." },
      8: { emoji:"💎", planet:"♄ Saturn", colors:"Black, Dark Blue, Dark Gold", days:"Saturday, Thursday", compat:"8, 4, 2", title:"The Executive", desc:"A number of power, wealth, achievement, and material success." },
      9: { emoji:"🌟", planet:"♂ Mars", colors:"Red, Gold, Crimson", days:"Tuesday, Thursday", compat:"9, 3, 6", title:"The Humanitarian", desc:"A number of completion, wisdom, service, and universal love." },
    };

    const luckyTable: Record<number, number[]> = {
      1:[1,10,19,28,2,4,7], 2:[2,11,20,29,1,7,4], 3:[3,12,21,30,6,9,5],
      4:[4,13,22,31,1,8,5], 5:[5,14,23,9,4,7,6], 6:[6,15,24,3,9,2,5],
      7:[7,16,25,1,2,6,3], 8:[8,17,26,4,3,9,5], 9:[9,18,27,3,6,5,4],
    };

    const tips = [
      ["📅 Schedule important meetings", "on your lucky day of the week"],
      ["🏡 Use your lucky number", "for house, flat, or car choices"],
      ["📞 Phone & ID numbers", "try to include your root number"],
      ["💒 Set big life dates", "on dates that add up to your number"],
      ["🎰 Games of chance", "play numbers from your lucky list"],
      ["💼 Business decisions", "make them when the date = your number"],
    ];

    document.getElementById('luckyNumberForm')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const dobInput = (document.getElementById('dob') as HTMLInputElement).value;
      if (!dobInput) return;

      const [year, month, day] = dobInput.split('-').map(Number);
      const rootNum = reduce(day);
      const lifePath = reduce(reduce(day) + reduce(month) + reduce(year));

      const luckyNums = [...new Set([rootNum, lifePath, ...(luckyTable[rootNum] || [])])].sort((a,b) => a-b).slice(0,9);

      const rootData = numInfo[rootNum] ?? numInfo[1];
      const lpData = numInfo[lifePath] ?? numInfo[1];

      // Numbers grid
      const grid = document.getElementById('numbersGrid') as HTMLElement;
      grid.innerHTML = luckyNums.map((n, i) =>
        `<div class="group flex flex-col items-center">
          <div class="w-14 h-14 md:w-16 md:h-16 rounded-full num-badge-${Math.min(n,9)} flex items-center justify-center text-xl md:text-2xl font-black text-white shadow-xl group-hover:scale-110 transition-transform duration-200" style="animation-delay:${i*0.1}s">
            ${n}
          </div>
          ${i === 0 ? '<span class="text-xs themed-text-3 mt-1.5">Root</span>' : i === 1 ? '<span class="text-xs themed-text-3 mt-1.5">Path</span>' : '<span class="text-xs themed-text-3 mt-1.5">Lucky</span>'}
        </div>`
      ).join('');

      (document.getElementById('numbersDesc') as HTMLElement).textContent =
        `Your root number is ${rootNum} (born on the ${day}th), and your life path is ${lifePath}. Use all ${luckyNums.length} numbers above for important life decisions, dates, and opportunities.`;

      // Root number card
      const rootBadge = document.getElementById('rootBadge') as HTMLElement;
      rootBadge.className = `w-14 h-14 rounded-xl flex items-center justify-center text-2xl font-black text-white shrink-0 num-badge-${Math.min(rootNum,9)}`;
      rootBadge.textContent = `${rootData.emoji}${rootNum}`;
      (document.getElementById('rootTitle') as HTMLElement).textContent = `${rootNum} — ${rootData.title}`;
      (document.getElementById('rootDesc') as HTMLElement).textContent = rootData.desc;
      (document.getElementById('rootColors') as HTMLElement).textContent = rootData.colors;
      (document.getElementById('rootPlanet') as HTMLElement).textContent = rootData.planet;

      // Life path card
      const lpBadge = document.getElementById('lpBadge') as HTMLElement;
      lpBadge.className = `w-14 h-14 rounded-xl flex items-center justify-center text-2xl font-black text-white shrink-0 num-badge-${Math.min(lifePath,9)}`;
      lpBadge.textContent = `${lpData.emoji}${lifePath}`;
      (document.getElementById('lpTitle') as HTMLElement).textContent = `${lifePath} — ${lpData.title}`;
      (document.getElementById('lpDesc') as HTMLElement).textContent = lpData.desc;
      (document.getElementById('lpDays') as HTMLElement).textContent = lpData.days;
      (document.getElementById('lpCompat') as HTMLElement).textContent = lpData.compat;

      // Tips
      const tipsEl = document.getElementById('timingTips') as HTMLElement;
      tipsEl.innerHTML = tips.map(([title, desc]) =>
        `<div class="flex items-start gap-3 p-3 rounded-xl bg-[var(--bg-secondary)]">
          <span class="text-lg shrink-0">${title.split(' ')[0]}</span>
          <div>
            <p class="text-xs font-semibold themed-text">${title.substring(3)}</p>
            <p class="text-xs themed-text-3">${desc}</p>
          </div>
        </div>`
      ).join('');

      const rc = document.getElementById('resultContainer') as HTMLElement;
      rc.classList.remove('hidden');
      setTimeout(() => rc.scrollIntoView({ behavior:'smooth', block:'start' }), 100);
    });
  </script>
</Layout>
