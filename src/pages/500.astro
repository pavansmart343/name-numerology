---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Server Error"
  description="Something went wrong while loading this page. Return to Name Numerology Hub or try one of our core calculators."
>
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4 py-20">
    <p class="text-8xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 mb-4">500</p>
    <h1 class="text-3xl font-bold themed-text mb-4">Something Went Wrong</h1>
    <p class="themed-text-2 max-w-md mb-8">
      The page could not load correctly. Please try again in a moment, or return to one of our numerology tools.
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/" class="bg-white text-black px-8 py-3 rounded-full font-semibold hover:bg-zinc-200 transition-colors">Go Home</a>
      <a href="/name-analysis" class="bg-zinc-900 text-white border border-zinc-700 px-8 py-3 rounded-full font-semibold hover:bg-zinc-800 transition-colors">Name Hub</a>
    </div>
  </div>
</Layout>
