---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found" description="The page you are looking for could not be found.">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4 py-20">
    <p class="text-8xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 mb-4">404</p>
    <h1 class="text-3xl font-bold text-white mb-4">Page Not Found</h1>
    <p class="text-zinc-400 max-w-md mb-8">Sorry, we couldn't find the page you were looking for. It may have been moved, deleted, or never existed.</p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/" class="bg-white text-black px-8 py-3 rounded-full font-semibold hover:bg-zinc-200 transition-colors">Go Home</a>
      <a href="/name-analysis" class="bg-zinc-900 text-white border border-zinc-700 px-8 py-3 rounded-full font-semibold hover:bg-zinc-800 transition-colors">Name Hub</a>
    </div>
  </div>
</Layout>
